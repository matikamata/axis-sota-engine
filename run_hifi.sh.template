#!/bin/bash
# Template de invocação — NÃO contém chaves.
# Copie para run_hifi.sh e preencha via `pass` ou variável de ambiente:
#
#   export DEEPL_API_KEY="$(pass show apis/deepl)"
#   export OPENAI_API_KEY="$(pass show apis/openai)"
#
source ~/HiFiOss/env/bin/activate
export DEEPL_API_KEY="${DEEPL_API_KEY:?Defina DEEPL_API_KEY antes de rodar}"
export OPENAI_API_KEY="${OPENAI_API_KEY:?Defina OPENAI_API_KEY antes de rodar}"
export HIFI_MODE="LIVE"
export HIFI_SACRED="TRUE"
python3 neon_chronos.py
